swift-sidecar/Package.resolved

# Built sidecar binary (regenerated by scripts/build-diarizer.sh).
# yt-dlp/ffmpeg/whisper-cli are checked in (small + redistributable);
# saucebunny-diarize is per-developer + signed by the bundler.
src-tauri/binaries/saucebunny-diarize-*

